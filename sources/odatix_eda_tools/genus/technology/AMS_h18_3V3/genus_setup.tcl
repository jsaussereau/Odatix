#-----------------------------------------------------------------------------
# TECHNOLOGY PATHS
#-----------------------------------------------------------------------------
set LIB_PATH  /asic/pdk/ams/AMS_410_CDS/liberty/c35_3.3V

#-----------------------------------------------------------------------------
# SEARCH PATHS
#-----------------------------------------------------------------------------
set LIB_SEARCH_PATHS [list]

lappend LIB_SEARCH_PATHS .
lappend LIB_SEARCH_PATHS $LIB_PATH

# Apply search paths
set_db init_lib_search_path $LIB_SEARCH_PATHS

#-----------------------------------------------------------------------------
# TIMING LIBRARIES
#-----------------------------------------------------------------------------
set LIBS [list]

# Worst Case library
lappend LIBS h18_IOLIB_WC.lib

#-----------------------------------------------------------------------------
# READ LIBRARIES
#-----------------------------------------------------------------------------
foreach lib $LIBS {
    read_libs $lib
}

